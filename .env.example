# Bricklayer environment. Copy to `.env.local` to override the committed `.env`.
# NEXT_PUBLIC_* values are inlined into the client bundle — NOT secrets.
# Keep real tokens/keys on your server, never here.

# Which data source the adapter factory uses (src/data/adapters/index.ts):
#   mock → seeded localStorage fixtures (the demo; works with zero setup)
#   api  → your real backend (implement src/data/adapters/api-adapter.ts)
# See docs/INTEGRATING-REAL-DATA.md before switching to `api`.
NEXT_PUBLIC_DATA_SOURCE=mock

# Base URL for the real API (only used when NEXT_PUBLIC_DATA_SOURCE=api):
# NEXT_PUBLIC_API_BASE_URL=https://your-api.example.com
